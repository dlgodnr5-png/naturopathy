# ─────────────────────────────────────────────────────────────
# PayPal (이해욱 개인계정 수취 연동)
# ─────────────────────────────────────────────────────────────
# sandbox(테스트) / live(실거래)
PAYPAL_MODE=sandbox

# PayPal 개발자 대시보드 > Apps & Credentials 에서 발급한 REST 앱 자격 증명
# (이해욱 개인계정으로 로그인하여 발급. 운영 결제 수취 시 Business 업그레이드 필요)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# 결제 통화 (PayPal은 KRW 결제를 지원하지 않음 → USD 권장)
PAYPAL_CURRENCY=USD

# KRW → USD 환산 환율 (서버에서 결제 금액 계산 시 사용)
PAYPAL_KRW_RATE=1350

# 이해욱 개인계정 이메일 (참고/검증용)
PAYPAL_RECEIVER_EMAIL=

# 브라우저(Smart Buttons)에서 사용하는 공개 값 — Client ID 와 동일하게 설정
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
NEXT_PUBLIC_PAYPAL_CURRENCY=USD

# ─────────────────────────────────────────────────────────────
# NextAuth (기존)
# ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
